# Copy this file to .env and fill only the keys/tools you need.
# Never commit real API keys or private local paths.

# Gemini API dubbing.
GEMINI_API_KEY=""

# Optional: force yt-dlp's JavaScript runtime for YouTube extraction.
# Leave empty to auto-detect deno or node. Use "off" to disable.
YTDLP_JS_RUNTIME=""

# Optional: ElevenLabs API dubbing.
ELEVENLABS_API_KEY=""

# Optional: local AI dubbing stack.
# Use either OpenAI Whisper's `whisper` command or whisper.cpp's `whisper-cli`.
WHISPER_BIN="whisper"
WHISPER_MODEL="large-v3"
WHISPER_LANGUAGE="auto"

# Ollama translates the transcript locally.
OLLAMA_BIN="ollama"
OLLAMA_MODEL="llama3.1:8b"

# Piper generates local speech. PIPER_VOICE must point to a .onnx voice model.
PIPER_BIN="piper"
PIPER_VOICE="/path/to/piper/voice.onnx"
